# ==========================================
# DriveMaster SDK - Professional .gitignore
# ==========================================

# --- OS Metadata ---
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# --- Environment & Secrets ---
# لا ترفع أبداً مفاتيح التشفير أو إعداداتك الخاصة
.env
.env.local
.env.*.local
*.pem
*.key

# --- Build Outputs ---
# استثناء مجلدات بناء الموقع الساكن (Jekyll, Docusaurus, Next.js)
_site/
.sass-cache/
.jekyll-metadata
.jekyll-cache/
dist/
build/
out/
.next/

# --- Dependency Managers ---
# هذه المجلدات يتم تحميلها برمجياً ولا تُرفع للمستودع
node_modules/
jspm_packages/
.pnpm-store/
.npm/
vendor/

# --- Editor & IDE Settings ---
# استثناء إعدادات المحرر لضمان مرونة العمل لكل مطور
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# --- Logs & Diagnostics ---
# ملفات السجلات والأخطاء
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Temporary Files ---
tmp/
temp/
.cache/
